# ============================================================
# ABC Centre — Variables de entorno
# Copia este archivo a .env.local y rellena los valores reales
# ============================================================

# ----------------------------------------------------------
# Google Calendar API (Service Account)
# Docs: https://developers.google.com/calendar/api/guides/auth
# ----------------------------------------------------------

# Email de la Service Account (formato: nombre@proyecto.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Clave privada de la Service Account (incluyendo -----BEGIN/END PRIVATE KEY-----)
# En .env.local escríbela en una sola línea con \n para los saltos de línea
GOOGLE_PRIVATE_KEY=

# IDs de los calendarios de Google Calendar por especialidad
# Se obtienen en Google Calendar > Configuración del calendario > ID del calendario
GOOGLE_CALENDAR_ID_LOGOPEDIA=
GOOGLE_CALENDAR_ID_PSICOLOGIA=
GOOGLE_CALENDAR_ID_NEUROPSICOLOGIA=
GOOGLE_CALENDAR_ID_PSICOPEDAGOGIA=
GOOGLE_CALENDAR_ID_TEA=
GOOGLE_CALENDAR_ID_VOZ=
GOOGLE_CALENDAR_ID_FAMILIAR=
GOOGLE_CALENDAR_ID_GENERAL=

# ----------------------------------------------------------
# Email transaccional (para notificaciones de reservas)
# Recomendado: Resend (https://resend.com) — plan gratuito incluido
# ----------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@abccentre.es
RESEND_NOTIFY_EMAIL=info@abccentre.es

# ----------------------------------------------------------
# URL del sitio (sin trailing slash)
# ----------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://abccentre.es
