# ─────────────────────────────────────────────────────────────────────────────
# ABC Centre — .env.local.example
# Copia a .env.local y rellena los valores. Nunca subas .env.local a git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Service Account ────────────────────────────────────────────────────
# Proyecto GCP: seismic-sweep-497513-g9
# Service account: abc-calendar@seismic-sweep-497513-g9.iam.gserviceaccount.com
#
# La clave privada viene del JSON descargado de Google Cloud Console.
# En .env.local escríbela en una línea con \n para los saltos de línea.
# (El código hace .replace(/\\n/g, '\n') internamente)
#
GOOGLE_SERVICE_ACCOUNT_EMAIL=abc-calendar@seismic-sweep-497513-g9.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ── Google Calendar IDs ───────────────────────────────────────────────────────
# PASO 1: Compartir el/los calendario(s) con el service account:
#   abc-calendar@seismic-sweep-497513-g9.iam.gserviceaccount.com
#   Permiso: "Realizar cambios en eventos"
#
# PASO 2: Obtener el Calendar ID:
#   Google Calendar → ⚙ Configuración → [Nombre calendario] → "ID del calendario"
#   Formato: direccion@gmail.com  o  c_xxxxxxxx@group.calendar.google.com
#
# Opción A — Un solo calendario para todas las citas:
#   GOOGLE_CALENDAR_ID_GENERAL=citas@abccentre.es
#   (dejar el resto vacíos — usan el GENERAL como fallback automático)
#
# Opción B — Un calendario por especialidad (recomendado a largo plazo):
#   GOOGLE_CALENDAR_ID_LOGOPEDIA=logopedia@abccentre.es
#   GOOGLE_CALENDAR_ID_PSICOLOGIA=psicologia@abccentre.es
#   etc.
#
GOOGLE_CALENDAR_ID_GENERAL=
GOOGLE_CALENDAR_ID_LOGOPEDIA=
GOOGLE_CALENDAR_ID_PSICOLOGIA=
GOOGLE_CALENDAR_ID_NEUROPSICOLOGIA=

# ── Emails de notificación por servicio (opcional) ────────────────────────────
# Si no se configuran, todas las notificaciones van a citas@abccentre.es
#
# NOTIFY_EMAIL_LOGOPEDIA=logopeda@abccentre.es
# NOTIFY_EMAIL_PSICOLOGIA=psicologa@abccentre.es
# NOTIFY_EMAIL_NEUROPSICOLOGIA=neuropsicologia@abccentre.es
# NOTIFY_EMAIL_GENERAL=citas@abccentre.es

# ── Gmail API (para envío de emails de confirmación) ──────────────────────────
# Requiere Domain-wide Delegation en Google Workspace Admin.
# Si no está configurado, los emails se loguean en consola (no se envían).
#
# Setup:
#   1. Google Workspace Admin → Seguridad → Controles de API → Delegación en todo el dominio
#   2. ID de cliente: 112881293920658965427
#   3. Ámbitos: https://www.googleapis.com/auth/gmail.send
#
GMAIL_SENDER_EMAIL=noreply@abccentre.es
GMAIL_INTERNAL_RECIPIENT=citas@abccentre.es

# ── Sitio ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://abccentre.es
