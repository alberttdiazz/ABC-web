# ─────────────────────────────────────────────────────────────────────────────
# ABC Centre — .env.local.example
# Copy to .env.local and fill in real values. Never commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Service Account ────────────────────────────────────────────────────
# Create a Service Account in Google Cloud Console:
#   https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable APIs: Google Calendar API + Gmail API
# Download the JSON key and copy the fields below.
#
GOOGLE_SERVICE_ACCOUNT_EMAIL=abc-centre-calendar@your-project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ── Google Calendar IDs ───────────────────────────────────────────────────────
# Each specialist's Google Calendar must be SHARED with the service account
# (with "Make changes to events" permission).
# Calendar ID is found in: Google Calendar → Settings → [Calendar name] → Calendar ID
# For personal Google accounts it's usually the email address.
#
GOOGLE_CALENDAR_ID_LOGOPEDIA=logopedia@abccentre.es
GOOGLE_CALENDAR_ID_PSICOLOGIA=psicologia@abccentre.es
GOOGLE_CALENDAR_ID_NEUROPSICOLOGIA=neuropsicologia@abccentre.es
# The following services share the general calendar (client to confirm):
GOOGLE_CALENDAR_ID_GENERAL=citas@abccentre.es

# ── Gmail API ─────────────────────────────────────────────────────────────────
# Domain-wide delegation is required to send email via the Gmail API.
# Setup in Google Workspace Admin Console:
#   Security → API Controls → Domain-wide Delegation → Add new
#   Client ID: the service account's OAuth2 client ID (numeric)
#   Scopes: https://www.googleapis.com/auth/gmail.send
#
# GMAIL_SENDER_EMAIL must be an existing Google Workspace user in the domain.
# Confirmation emails will appear to come from this address.
#
GMAIL_SENDER_EMAIL=noreply@abccentre.es
# Internal recipient for new-booking notifications (defaults to citas@abccentre.es):
GMAIL_INTERNAL_RECIPIENT=citas@abccentre.es

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://abccentre.es
